# Solo Agentic Demo — environment template
#
# Copy this file to .env and fill in real values:
#     cp .env.example .env
#
# .env is gitignored, so your keys never get committed. setup.sh and demo.sh
# source .env automatically (no need to export anything by hand).

# ── Required: LLM provider API keys ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Required: GitHub OAuth App (for the elicitation / OBO demo) ───────────────
# Create at: GitHub → Settings → Developer settings → OAuth Apps → New
#   Homepage URL:               http://localhost:9090
#   Authorization callback URL: http://localhost:9090/age/elicitations   ← must match exactly
GITHUB_CLIENT_ID=Iv1....
GITHUB_CLIENT_SECRET=...

# ── Solo licenses (needed unless you generate them from the licensing repo) ───
# Solo employees can skip this — setup.sh auto-generates licenses from the
# solo-io/licensing repo if it's cloned at ~/licensing (LICENSING_REPO below).
# Everyone else: provide license string(s) here, or paste them when prompted.
#
# Easiest: ONE trial license that covers all products —
# SOLO_LICENSE_KEY=eyJ...
#
# Or set them per-product (overrides SOLO_LICENSE_KEY for that product):
# AGENTGATEWAY_LICENSE_KEY=eyJ...
# SOLO_ISTIO_LICENSE_KEY=eyJ...
# KAGENT_LICENSE_KEY=eyJ...

# ── Optional overrides (any config var in setup.sh can go here) ───────────────
# Uncomment to change defaults:
# LICENSING_REPO=/Users/you/licensing
# CLUSTER_NAME=ai-demo
# AGW_VERSION=v2026.6.0
# KAGENT_ENT_VERSION=0.3.17
# AR_VERSION=2026.5.4
