# Solo Agentic Demo — environment template
#
# Copy this file to .env and fill in real values:
#     cp .env.example .env
#
# .env is gitignored, so your keys never get committed. setup.sh and demo.sh
# source .env automatically (no need to export anything by hand).

# ── Required: LLM provider API keys ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Required: GitHub OAuth App (for the elicitation / OBO demo) ───────────────
# Create at: GitHub → Settings → Developer settings → OAuth Apps → New
#   Homepage URL:               http://localhost:9090
#   Authorization callback URL: http://localhost:9090/age/elicitations   ← must match exactly
GITHUB_CLIENT_ID=Iv1....
GITHUB_CLIENT_SECRET=...

# ── Optional overrides (any config var in setup.sh can go here) ───────────────
# Uncomment to change defaults:
# LICENSING_REPO=/Users/you/licensing
# CLUSTER_NAME=ai-demo
# AGW_VERSION=v2026.5.2
# KAGENT_ENT_VERSION=0.3.17
# AR_VERSION=2026.5.4
